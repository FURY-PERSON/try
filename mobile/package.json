{
  "name": "fact-front-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android:development-debug": "ENVFILE=.env.development npx expo run:android --variant=developmentDebug",
    "android:development-release": "ENVFILE=.env.development npx expo run:android --variant=developmentRelease",
    "android:stage-debug": "ENVFILE=.env.stage npx expo run:android --variant=stageDebug",
    "android:stage-release": "ENVFILE=.env.stage npx expo run:android --variant=stageRelease",
    "android:production-debug": "ENVFILE=.env.production npx expo run:android --variant=productionDebug",
    "android:production-release": "ENVFILE=.env.production npx expo run:android --variant=productionRelease",
    "ios:development-debug": "ENVFILE=.env.development npx expo run:ios --scheme 'Frontfaktov (Development)' --configuration Debug",
    "ios:development-release": "ENVFILE=.env.development npx expo run:ios --scheme 'Frontfaktov (Development)' --configuration Release",
    "ios:stage-debug": "ENVFILE=.env.stage npx expo run:ios --scheme 'Frontfaktov (Stage)' --configuration Debug",
    "ios:stage-release": "ENVFILE=.env.stage npx expo run:ios --scheme 'Frontfaktov (Stage)' --configuration Release",
    "ios:production-debug": "ENVFILE=.env.production npx expo run:ios --scheme 'Frontfaktov (Production)' --configuration Debug",
    "ios:production-release": "ENVFILE=.env.production npx expo run:ios --scheme 'Frontfaktov (Production)' --configuration Release",
    "aab:development": "cd android && ENVFILE=.env.development ./gradlew :app:clean bundleDevelopmentRelease && V=$(grep VERSION_NAME ../.env.development | cut -d= -f2) && D=$(date +%Y%m%d) && mv app/build/outputs/bundle/developmentRelease/app-development-release.aab app/build/outputs/bundle/developmentRelease/factfront-development-${V}-${D}.aab",
    "aab:stage": "cd android && ENVFILE=.env.stage ./gradlew :app:clean bundleStageRelease && V=$(grep VERSION_NAME ../.env.stage | cut -d= -f2) && D=$(date +%Y%m%d) && mv app/build/outputs/bundle/stageRelease/app-stage-release.aab app/build/outputs/bundle/stageRelease/factfront-stage-${V}-${D}.aab",
    "aab:production": "cd android && ENVFILE=.env.production ./gradlew :app:clean bundleProductionRelease && V=$(grep VERSION_NAME ../.env.production | cut -d= -f2) && D=$(date +%Y%m%d) && mv app/build/outputs/bundle/productionRelease/app-production-release.aab app/build/outputs/bundle/productionRelease/factfront-production-${V}-${D}.aab",
    "start": "expo start --reset-cache",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "jest",
    "postinstall": "node scripts/postinstall.js",
    "clean": "react-native-clean-project",
    "clean:android": "cd android && ./gradlew :app:clean",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.2.3",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "5.2.8",
    "@hookform/resolvers": "^5.2.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.2",
    "expo": "~55.0.6",
    "expo-build-properties": "~55.0.13",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.13",
    "expo-navigation-bar": "~55.0.12",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-tracking-transparency": "~55.0.13",
    "expo-updates": "~55.0.20",
    "i18next": "^25.8.13",
    "react": "19.2.5",
    "react-hook-form": "7.71.2",
    "react-i18next": "^16.5.4",
    "react-native": "0.83.4",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "unity-levelplay-mediation": "^9.0.0",
    "react-native-worklets": "0.7.2",
    "zod": "^4.1.1",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.0",
    "react-native-clean-project": "^4.0.3",
    "typescript": "~5.9.2"
  }
}
