{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "ENVFILE": ".env.development"
      },
      "ios": {
        "simulator": true,
        "scheme": "Frontfaktov (Development)"
      },
      "android": {
        "gradleCommand": ":app:assembleDevelopmentDebug"
      }
    },
    "stage": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "ENVFILE": ".env.stage"
      },
      "ios": {
        "simulator": true,
        "scheme": "Frontfaktov (Stage)"
      },
      "android": {
        "gradleCommand": ":app:assembleStageRelease"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "ENVFILE": ".env.production"
      },
      "ios": {
        "scheme": "Frontfaktov (Production)"
      },
      "android": {
        "gradleCommand": ":app:assembleProductionRelease"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "ENVFILE": ".env.production"
      },
      "ios": {
        "scheme": "Frontfaktov (Production)"
      },
      "android": {
        "gradleCommand": ":app:assembleProductionRelease"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID",
        "ascAppId": "YOUR_ASC_APP_ID",
        "appleTeamId": "YOUR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      }
    }
  }
}
